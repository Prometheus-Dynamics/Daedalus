        { "name": "a", "ty": { "Scalar": "Int" }, "const_value": 2 },
        { "name": "b", "ty": { "Scalar": "Int" }, "const_value": 3 }
      ],
      "outputs": [
        { "name": "out", "ty": { "Scalar": "Int" } }
      ]
    }
  ]
}

