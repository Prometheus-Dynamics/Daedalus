{
  "manifest_version": "1",
  "language": "python",
  "plugin": {
    "name": "generated_py_plugin",
    "version": "0.1.1",
    "description": "Embedded python manifest example"
  },
  "nodes": [
    {
      "id": "generated_py_plugin:add",
